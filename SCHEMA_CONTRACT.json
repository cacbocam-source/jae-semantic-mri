{
  "version": "2.1",
  "date": "2026-03-19",
  "project_root": "/Volumes/Clemons_Data/_Anchors/Research_Data/JAE_Legacy_Audit",
  "routes": [
    "Route_A_Modern",
    "Route_B_Legacy"
  ],
  "structured_export": {
    "format": "json",
    "path_pattern": "data/structured/{route_name}/{doc_id}.json",
    "required_fields": [
      "doc_id",
      "source_filename",
      "source_pdf_path",
      "route",
      "year",
      "extraction_method",
      "page_count",
      "raw_text_length",
      "clean_text_length",
      "segmentation_strategy",
      "A_intro",
      "A_methods",
      "A_results"
    ],
    "required_sections": [
      "A_intro",
      "A_methods",
      "A_results"
    ],
    "forbidden_fields_or_shapes": [
      "sections",
      "A_Intro",
      "A_Methods",
      "A_Results"
    ],
    "notes": [
      "A_TAK is a segmentation-stage internal artifact and is not part of the structured export contract."
    ]
  },
  "year_resolution": {
    "authoritative_source_when_available": "manifest_row.year",
    "fallback_precedence": [
      "explicit legacy filename map",
      "supported filename parsing"
    ],
    "legacy_map_path": "data/manifests/legacy_filename_year_map.csv",
    "supported_filename_patterns": [
      "JAE_YYYY_NNNN.pdf",
      "bare-year filenames such as YYYY.pdf",
      "filenames containing exactly one valid standalone 4-digit year"
    ],
    "failure_mode": "raise error if year cannot be resolved deterministically",
    "notes": [
      "Unsupported filenames must not silently guess a year.",
      "Legacy exceptions belong in the explicit mapping CSV, not in hardcoded benchmark-only conditionals inside active export code."
    ]
  },
  "embedding_bundle": {
    "format": "npz",
    "path_pattern": "data/embeddings/{route_name}/{doc_id}.npz",
    "required_fields": [
      "doc_id",
      "route",
      "section_labels",
      "embeddings",
      "source_path"
    ],
    "notes": [
      "Bundles store section embeddings, not a single manuscript-level vector.",
      "Year is not read from embedding bundles by the Phase 5 metrics stage."
    ]
  },
  "manifest": {
    "format": "csv",
    "path": "data/manifests/pipeline_manifest.csv",
    "required_stage_fields": [
      "extract_status",
      "structured_status",
      "embedding_status",
      "metrics_status"
    ],
    "required_minimum_semantics": [
      "doc identity tracking",
      "route tracking",
      "year tracking",
      "source-path tracking",
      "error-state tracking"
    ],
    "allowed_status_values": [
      "pending",
      "success",
      "failed",
      "skipped"
    ],
    "phase5_temporal_join_field": "year"
  },
  "metrics_artifact": {
    "format": "npz",
    "granularity": "route",
    "output_path_pattern": "data/metrics/{route_name}/metrics.npz",
    "input_dependency": "validated Phase 4 embedding bundles",
    "year_source": "manifest-row join",
    "notes": [
      "Metrics artifacts are route-level outputs, not document-level outputs.",
      "metrics_status may be marked success only after successful artifact persistence."
    ]
  },
  "terminology": {
    "preferred": [
      "section embeddings",
      "route-level metrics artifacts"
    ],
    "avoid": [
      "manuscript vectors",
      "document-level metrics artifacts"
    ]
  }
}
