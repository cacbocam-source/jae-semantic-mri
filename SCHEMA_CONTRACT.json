  },
  "metrics_artifact": {
    "format": "npz",
    "granularity": "route",
    "output_path_pattern": "data/metrics/{route_name}/metrics.npz",
    "input_dependency": "validated Phase 4 embedding bundles",
    "year_source": "manifest-row join",
    "required_fields": [
      "corpus_name",
      "route_name",
      "epoch_labels",
      "epoch_counts",
      "epoch_centroids",
      "semantic_dispersion",
      "innovation_velocity",
